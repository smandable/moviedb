{
  "name": "movie-db",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "add-page": "ng g m pages/page-name --routing && ng g component pages/page-name --skip-tests",
